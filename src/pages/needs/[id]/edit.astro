---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import { getDb, schema } from '../../../db';
import { eq } from 'drizzle-orm';
import { categoryLabels } from '../../../lib/constants';

// Auth check
const session = Astro.locals.session;
if (!session?.user) {
  return Astro.redirect(`/auth/signin?callbackUrl=/needs/${Astro.params.id}/edit`);
}

const db = getDb();

// Look up the current user to get their orgId
const user = await db.query.users.findFirst({
  where: eq(schema.users.id, session.user.id),
});

if (!user?.orgId || user.role !== 'organizer') {
  return Astro.redirect('/');
}

// Load the need
const { id } = Astro.params;
const need = await db.query.needs.findFirst({
  where: eq(schema.needs.id, id!),
});

if (!need) {
  return Astro.redirect('/404');
}

// Verify the user's org owns this need
if (need.orgId !== user.orgId) {
  return Astro.redirect('/');
}

// Compute remaining days from expiresAt for the select default
const msPerDay = 1000 * 60 * 60 * 24;
const daysLeft = Math.max(0, Math.round((need.expiresAt.getTime() - Date.now()) / msPerDay));

// Map to closest select option
function closestExpiry(days: number): number {
  if (days <= 30) return 30;
  if (days <= 60) return 60;
  if (days <= 90) return 90;
  return 180;
}
const expiresInDays = closestExpiry(daysLeft);
---

<Layout title={`Edit: ${need.title}`}>
  <div class="max-w-3xl">
    <a href={`/needs/${need.id}`} class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-[#2D4A2D] mb-4">
      &larr; Back to need
    </a>

    <h1 class="text-3xl font-bold mb-3">Edit Need</h1>
    <p class="text-gray-600 mb-8">
      Update the details for this need. Changes will be visible immediately.
    </p>

    <form method="POST" action={`/api/needs/${need.id}`} class="space-y-6">
      {/* Category */}
      <div>
        <label for="categoryTag" class="block text-sm font-medium text-gray-700 mb-1">
          Category
        </label>
        <select
          id="categoryTag"
          name="categoryTag"
          class="border rounded-lg px-3 py-2 text-sm"
        >
          {Object.entries(categoryLabels).map(([value, label]) => (
            <option value={value} selected={need.categoryTag === value}>{label}</option>
          ))}
        </select>
      </div>

      {/* Title */}
      <div>
        <label for="title" class="block text-sm font-medium text-gray-700 mb-1">
          Title
        </label>
        <input
          id="title"
          name="title"
          type="text"
          required
          minlength="5"
          maxlength="200"
          value={need.title}
          placeholder="e.g., Running shoes for Wilson High cross country team"
          class="w-full border rounded-lg px-3 py-2 text-sm"
        />
      </div>

      {/* Body */}
      <div>
        <label for="body" class="block text-sm font-medium text-gray-700 mb-1">
          What do you need?
        </label>
        <textarea
          id="body"
          name="body"
          required
          minlength="10"
          maxlength="5000"
          rows="8"
          placeholder="Describe what your runners need."
          class="w-full border rounded-lg px-3 py-2 text-sm font-mono"
        >{need.body}</textarea>
        <p class="text-xs text-gray-400 mt-1">
          Include sizes, quantities, and any condition preferences.
        </p>
      </div>

      {/* Extras welcome */}
      <label class="flex items-center gap-2 text-sm">
        <input
          type="checkbox"
          name="extrasWelcome"
          checked={need.extrasWelcome}
          class="rounded border-gray-300"
        />
        <span>
          Extras welcome &mdash; additional items beyond the specific request are useful
        </span>
      </label>

      {/* Expiration */}
      <div>
        <label for="expiresInDays" class="block text-sm font-medium text-gray-700 mb-1">
          Expires in
        </label>
        <select
          id="expiresInDays"
          name="expiresInDays"
          class="border rounded-lg px-3 py-2 text-sm"
        >
          <option value="30" selected={expiresInDays === 30}>1 month</option>
          <option value="60" selected={expiresInDays === 60}>2 months</option>
          <option value="90" selected={expiresInDays === 90}>3 months</option>
          <option value="180" selected={expiresInDays === 180}>6 months</option>
        </select>
        <p class="text-xs text-gray-400 mt-1">
          This will reset the expiration date from today.
        </p>
      </div>

      <div class="flex gap-3">
        <button
          id="edit-submit-btn"
          type="submit"
          class="bg-green-700 text-white px-6 py-2 rounded-lg hover:bg-green-800 text-sm disabled:opacity-50"
        >
          Save Changes
        </button>
        <a
          href={`/needs/${need.id}`}
          class="px-6 py-2 rounded-lg border border-gray-300 text-sm text-gray-700 hover:bg-gray-50"
        >
          Cancel
        </a>
      </div>
    </form>

    <script>
      const editForm = document.querySelector('form[action^="/api/needs/"]') as HTMLFormElement;
      editForm?.addEventListener('submit', () => {
        const btn = document.getElementById('edit-submit-btn') as HTMLButtonElement;
        btn.disabled = true;
        btn.textContent = 'Saving...';
      });
    </script>
  </div>
</Layout>
