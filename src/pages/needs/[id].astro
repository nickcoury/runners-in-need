---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import PledgeForm from "../../components/PledgeForm";
import { getDb, schema } from "../../db";
import { eq } from "drizzle-orm";

const { id } = Astro.params;
const db = getDb();

const needRow = await db.query.needs.findFirst({
  where: eq(schema.needs.id, id!),
  with: {
    organization: true,
    pledges: {
      with: {
        messages: {
          with: {
            sender: true,
          },
        },
      },
    },
    continuedFrom: true,
  },
});

if (!needRow) {
  return Astro.redirect("/404");
}

const need = {
  id: needRow.id,
  title: needRow.title,
  categoryTag: needRow.categoryTag,
  body: needRow.body,
  orgName: needRow.organization.name,
  location: needRow.location,
  extrasWelcome: needRow.extrasWelcome,
  status: needRow.status,
  expiresAt: needRow.expiresAt,
  pledgeCount: needRow.pledges.length,
  continuedFromId: needRow.continuedFrom?.id ?? null,
  continuedFromTitle: needRow.continuedFrom?.title ?? null,
  createdAt: needRow.createdAt,
};

const pledges = needRow.pledges.map((p) => ({
  id: p.id,
  donorName: p.donorName || "Anonymous",
  description: p.description,
  status: p.status,
  createdAt: p.createdAt,
  updatedAt: p.updatedAt,
  messages: p.messages.map((m) => ({
    id: m.id,
    author: m.sender.name,
    isOrg: m.sender.orgId === needRow.orgId,
    body: m.body,
    createdAt: m.createdAt,
  })),
}));

// Precompute all derived values
const categoryStyleMap: Record<string, string> = {
  shoes: "bg-[#2D4A2D] text-white",
  apparel: "bg-blue-600 text-white",
  accessories: "bg-amber-600 text-white",
  other: "bg-gray-500 text-white",
};

const categoryLabelMap: Record<string, string> = {
  shoes: "Shoes",
  apparel: "Apparel",
  accessories: "Accessories",
  other: "Other",
};

const categoryStyle = categoryStyleMap[need.categoryTag] || categoryStyleMap.other;
const categoryLabel = categoryLabelMap[need.categoryTag] || "Other";

const msPerDay = 1000 * 60 * 60 * 24;
const daysUntilExpiry = Math.ceil((need.expiresAt.getTime() - Date.now()) / msPerDay);
const isExpiringSoon = daysUntilExpiry <= 14 && daysUntilExpiry > 0;
const isExpired = daysUntilExpiry <= 0;
const expiryText = isExpired ? "Expired" : `${daysUntilExpiry} days left`;
const expiryClass = isExpiringSoon ? "text-amber-600 font-medium" : isExpired ? "text-red-600 font-medium" : "text-gray-500";

const hasContinuation = need.continuedFromId !== null;
const continuationUrl = hasContinuation ? `/needs/${need.continuedFromId}` : "";

const createdDateStr = need.createdAt.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" });
const expiresDateStr = need.expiresAt.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" });

const statusBadgeMap: Record<string, string> = {
  collecting: "bg-yellow-50 text-yellow-700 border-yellow-200",
  ready_to_deliver: "bg-green-50 text-green-700 border-green-200",
  delivered: "bg-blue-50 text-blue-700 border-blue-200",
  withdrawn: "bg-red-50 text-red-700 border-red-200",
};

const statusLabelMap: Record<string, string> = {
  collecting: "Collecting",
  ready_to_deliver: "Ready to Deliver",
  delivered: "Delivered",
  withdrawn: "Withdrawn",
};

const pledgesWithComputed = pledges.map((p) => {
  const badge = statusBadgeMap[p.status] || statusBadgeMap.pending;
  const label = statusLabelMap[p.status] || "Pending";
  const dateStr = p.createdAt.toLocaleDateString("en-US", { month: "short", day: "numeric" });
  const messagesWithDates = p.messages.map((m) => {
    const timeStr = m.createdAt.toLocaleString("en-US", {
      month: "short",
      day: "numeric",
      hour: "numeric",
      minute: "2-digit",
    });
    return { ...m, timeStr };
  });
  return { ...p, badge, label, dateStr, messagesWithDates };
});

const pledgeCountText = need.pledgeCount === 1 ? "1 pledge" : `${need.pledgeCount} pledges`;
---

<Layout title={need.title}>
  <div class="max-w-3xl mx-auto">
    {/* Back link */}
    <a href="/" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-[#2D4A2D] mb-4">
      &larr; Back to browse
    </a>

    {/* Continued-from banner */}
    {hasContinuation && (
      <div class="bg-blue-50 border border-blue-200 rounded-lg px-4 py-3 mb-4 text-sm text-blue-800">
        This need continues from a previous request.
        <a href={continuationUrl} class="underline font-medium hover:text-blue-900 ml-1">
          View original need &rarr;
        </a>
      </div>
    )}

    {/* Main need card */}
    <div class="bg-white border border-gray-200 rounded-lg p-6 mb-6">
      {/* Header: category + extras + expiry */}
      <div class="flex flex-wrap items-center gap-2 mb-3">
        <span class:list={["text-xs font-medium px-2.5 py-1 rounded-full", categoryStyle]}>
          {categoryLabel}
        </span>
        {need.extrasWelcome && (
          <span class="text-xs bg-green-50 text-green-700 px-2.5 py-1 rounded-full border border-green-200">
            + Extras welcome
          </span>
        )}
        <span class:list={["text-xs ml-auto", expiryClass]}>
          {expiryText}
        </span>
      </div>

      {/* Title */}
      <h1 class="text-2xl font-bold text-gray-900 mb-2">{need.title}</h1>

      {/* Org + location + date */}
      <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-gray-500 mb-4">
        <span class="font-medium text-gray-700">{need.orgName}</span>
        <span>&middot;</span>
        <span>{need.location}</span>
        <span>&middot;</span>
        <span>Posted {createdDateStr}</span>
      </div>

      {/* Metadata bar */}
      <div class="flex flex-wrap items-center gap-4 text-xs text-gray-400 border-t border-b border-gray-100 py-3 mb-4">
        <span>{pledgeCountText}</span>
        <span>Expires {expiresDateStr}</span>
        <span class="capitalize">Status: {need.status}</span>
      </div>

      {/* Body text */}
      <div class="text-sm text-gray-700 leading-relaxed whitespace-pre-line">{need.body}</div>
    </div>

    {/* Pledges section */}
    <div class="mb-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">Pledges ({need.pledgeCount})</h2>

      {pledgesWithComputed.length === 0 && (
        <div class="border border-dashed border-gray-300 rounded-lg p-8 text-center text-gray-400">
          <p class="mb-1">No pledges yet.</p>
          <p class="text-sm">Be the first to pledge gear for this need!</p>
        </div>
      )}

      <div class="space-y-4">
        {pledgesWithComputed.map((pledge) => (
          <div class="bg-white border border-gray-200 rounded-lg p-4">
            {/* Pledge header */}
            <div class="flex items-start justify-between gap-3 mb-2">
              <div>
                <span class="font-semibold text-gray-900 text-sm">{pledge.donorName}</span>
                <span class="text-xs text-gray-400 ml-2">{pledge.dateStr}</span>
              </div>
              <span class:list={["text-xs font-medium px-2 py-0.5 rounded-full border", pledge.badge]}>
                {pledge.label}
              </span>
            </div>

            {/* Pledge description */}
            <p class="text-sm text-gray-600 whitespace-pre-line mb-3">{pledge.description}</p>

            {/* Messages thread */}
            {pledge.messagesWithDates.length > 0 && (
              <div class="border-t border-gray-100 pt-3 mt-3">
                <p class="text-xs font-medium text-gray-500 mb-2">Messages</p>
                <div class="space-y-2">
                  {pledge.messagesWithDates.map((msg) => (
                    <div class:list={[
                      "rounded-lg px-3 py-2 text-sm",
                      msg.isOrg ? "bg-green-50 border border-green-100 ml-4" : "bg-gray-50 border border-gray-100 mr-4",
                    ]}>
                      <div class="flex items-center gap-2 mb-1">
                        <span class:list={[
                          "text-xs font-medium",
                          msg.isOrg ? "text-green-700" : "text-gray-700",
                        ]}>
                          {msg.author}
                        </span>
                        {msg.isOrg && (
                          <span class="text-[10px] bg-green-100 text-green-700 px-1.5 py-0.5 rounded font-medium">
                            ORG
                          </span>
                        )}
                        <span class="text-xs text-gray-400 ml-auto">{msg.timeStr}</span>
                      </div>
                      <p class="text-gray-700">{msg.body}</p>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>

    {/* Pledge form */}
    <div class="mb-8">
      <h2 class="text-lg font-bold text-gray-900 mb-4">Make a Pledge</h2>
      <PledgeForm client:load needId={need.id} turnstileSiteKey={import.meta.env.TURNSTILE_SITE_KEY} />
    </div>
  </div>
</Layout>
