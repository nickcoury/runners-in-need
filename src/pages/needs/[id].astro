---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import PledgeForm from "../../components/PledgeForm";
import { getDb, schema } from "../../db";
import { getEnv } from "../../lib/env";
import { eq } from "drizzle-orm";
import { categoryStyles, categoryLabels, pledgeStatusStyles, pledgeStatusLabels, deliveryMethodLabels } from "../../lib/constants";

const { id } = Astro.params;
const hasDbConfig = !!getEnv("TURSO_DATABASE_URL");
const db = hasDbConfig ? getDb() : null;

const needRow = db ? await db.query.needs.findFirst({
  where: eq(schema.needs.id, id!),
  with: {
    organization: true,
    pledges: {
      with: {
        messages: {
          with: {
            sender: { columns: { name: true, orgId: true } },
          },
        },
      },
    },
    continuedFrom: true,
  },
}) : null;

if (!needRow) {
  Astro.response.status = 404;
}

const need = needRow ? {
  id: needRow.id,
  orgId: needRow.orgId,
  title: needRow.title,
  categoryTag: needRow.categoryTag,
  body: needRow.body,
  orgName: needRow.organization?.name ?? "Unknown Organization",
  location: needRow.location,
  extrasWelcome: needRow.extrasWelcome,
  status: needRow.status,
  expiresAt: needRow.expiresAt,
  pledgeCount: needRow.pledges.length,
  continuedFromId: needRow.continuedFrom?.id ?? null,
  continuedFromTitle: needRow.continuedFrom?.title ?? null,
  createdAt: needRow.createdAt,
} : null;

const pledges = needRow ? needRow.pledges.map((p) => ({
  id: p.id,
  donorName: p.donorName || "Anonymous",
  description: p.description,
  status: p.status,
  createdAt: p.createdAt,
  updatedAt: p.updatedAt,
  messages: p.messages.map((m) => ({
    id: m.id,
    author: m.sender.name,
    isOrg: m.sender.orgId === needRow.orgId,
    body: m.body,
    createdAt: m.createdAt,
  })),
})) : [];

// Precompute all derived values
const categoryStyle = need ? categoryStyles[need.categoryTag] || categoryStyles.other : categoryStyles.other;
const categoryLabel = need ? categoryLabels[need.categoryTag] || "Other" : "Other";

const msPerDay = 1000 * 60 * 60 * 24;
const daysUntilExpiry = need ? Math.ceil((need.expiresAt.getTime() - Date.now()) / msPerDay) : 0;
const isExpiringSoon = daysUntilExpiry <= 14 && daysUntilExpiry > 0;
const isExpired = daysUntilExpiry <= 0;
const expiryText = isExpired ? "Expired" : daysUntilExpiry === 1 ? "1 day left" : `${daysUntilExpiry} days left`;
const expiryClass = isExpiringSoon ? "text-amber-700 font-medium" : isExpired ? "text-red-600 font-medium" : "text-gray-500";

const hasContinuation = !!need?.continuedFromId;
const continuationUrl = hasContinuation ? `/needs/${need?.continuedFromId}` : "";

const createdDateStr = need?.createdAt.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" }) ?? "";
const expiresDateStr = need?.expiresAt.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" }) ?? "";

const pledgeCountText = need ? need.pledgeCount === 1 ? "1 pledge" : `${need.pledgeCount} pledges` : "0 pledges";

// Check if current user can message on pledges
const session = Astro.locals.session;
const currentUserId = session?.user?.id;
let currentUserOrgId: string | null = null;
if (currentUserId) {
  const currentUser = db ? await db.query.users.findFirst({
    where: eq(schema.users.id, currentUserId),
    columns: { orgId: true },
  }) : null;
  currentUserOrgId = currentUser?.orgId ?? null;
}
const isOrgMember = currentUserOrgId === needRow?.orgId;

const showShipping = !!needRow?.organization?.showShippingAddress && !!needRow.organization?.shippingAddress;
const shippingAddress = needRow?.organization?.shippingAddress || "";
const shippingAttn = needRow?.organization?.shippingAttn || "";

// Resolve delivery methods: need-level override > org defaults
const effectiveDeliveryMethods: string[] = needRow?.deliveryMethods
  ? JSON.parse(needRow.deliveryMethods)
  : needRow?.organization?.deliveryMethods
    ? JSON.parse(needRow.organization.deliveryMethods)
    : [];
const effectiveDeliveryInstructions = needRow?.deliveryInstructions
  || needRow?.organization?.deliveryInstructions
  || "";

const pledgesWithComputed = pledges.map((p) => {
  const badge = pledgeStatusStyles[p.status] || pledgeStatusStyles.pending;
  const label = pledgeStatusLabels[p.status] || "Pending";
  const dateStr = p.createdAt.toLocaleDateString("en-US", { month: "short", day: "numeric" });
  const messagesWithDates = p.messages.map((m) => {
    const timeStr = m.createdAt.toLocaleString("en-US", {
      month: "short",
      day: "numeric",
      hour: "numeric",
      minute: "2-digit",
    });
    return { ...m, timeStr };
  });
  const canMessage = isOrgMember || (currentUserId && needRow?.pledges.find((np) => np.id === p.id)?.donorId === currentUserId);
  return { ...p, badge, label, dateStr, messagesWithDates, canMessage: !!canMessage };
});
---

<Layout title={need?.title ?? "Page Not Found"} description={need ? `${need.title} — ${need.orgName}, ${need.location}` : "This need could not be found."} ogType="article">
  {need ? (
  <div class="max-w-3xl mx-auto">
    {/* Back link */}
    <a href="/" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-[#2D4A2D] focus-visible:text-[#2D4A2D] focus-visible:outline-none mb-4">
      &larr; Back to browse
    </a>

    {/* Continued-from banner */}
    {hasContinuation && (
      <div class="bg-blue-50 border border-blue-200 rounded-lg px-4 py-3 mb-4 text-sm text-blue-800">
        This need continues from a previous request.
        <a href={continuationUrl} class="underline font-medium hover:text-blue-900 focus-visible:text-blue-900 focus-visible:outline-none ml-1">
          View original need &rarr;
        </a>
      </div>
    )}

    {/* Main need card */}
    <div class="bg-white border border-gray-200 rounded-lg p-4 sm:p-6 mb-6">
      {/* Header: category + extras + expiry */}
      <div class="flex flex-wrap items-center gap-2 mb-3">
        <span class:list={["text-xs font-medium px-2.5 py-1 rounded-full", categoryStyle]} data-testid="need-category-badge">
          {categoryLabel}
        </span>
        {need.extrasWelcome && (
          <span class="text-xs bg-green-50 text-green-700 px-2.5 py-1 rounded-full border border-green-200">
            + Extras welcome
          </span>
        )}
        <span class:list={["text-xs ml-auto", expiryClass]}>
          {expiryText}
        </span>
      </div>

      <div class="mb-3 flex flex-wrap items-center justify-between gap-3">
        <h1 class="text-2xl font-bold text-gray-900 break-words">{need.title}</h1>
        <button
          id="copy-need-link"
          type="button"
          class="inline-flex items-center gap-1 rounded-lg border border-gray-300 px-3 py-1.5 text-sm font-medium text-gray-700 hover:border-[#2D4A2D] hover:text-[#2D4A2D] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#2D4A2D]/50 focus-visible:ring-offset-2"
          aria-describedby="copy-need-link-status"
        >
          <svg class="h-4 w-4" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2M10 18h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
          Copy link
        </button>
      </div>
      <p id="copy-need-link-status" class="sr-only" aria-live="polite"></p>

      {/* Org + location + date */}
      <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-gray-500 mb-4" data-testid="need-meta-row">
        <a href={`/org/${need.orgId}`} class="font-medium text-gray-700 hover:text-[#2D4A2D] hover:underline focus-visible:text-[#2D4A2D] focus-visible:underline focus-visible:outline-none" data-testid="need-org-name">{need.orgName}</a>
        <span>&middot;</span>
        <span>{need.location}</span>
        <span>&middot;</span>
        <span>Posted {createdDateStr}</span>
      </div>

      {/* Metadata bar */}
      <div class="flex flex-wrap items-center gap-4 text-xs text-gray-500 border-t border-b border-gray-100 py-3 mb-4" data-testid="need-metadata-bar">
        <span class="flex items-center gap-1">
          <svg class="w-3.5 h-3.5" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
          {pledgeCountText}
        </span>
        <span class:list={["flex items-center gap-1", expiryClass]}>
          <svg class="w-3.5 h-3.5" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
          Expires {expiresDateStr}
        </span>
        <span class="capitalize flex items-center gap-1">
          <svg class="w-3.5 h-3.5" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2" /></svg>
          {need.status === 'active' ? 'Accepting pledges' : need.status === 'fulfilled' ? 'Fulfilled' : need.status === 'partially_fulfilled' ? 'Partially fulfilled' : need.status.replace('_', ' ')}
        </span>
      </div>

      {/* Body text */}
      <div class="text-sm text-gray-700 leading-relaxed whitespace-pre-line">{need.body}</div>

      {/* How to donate */}
      {effectiveDeliveryMethods.length > 0 && (
        <div class="mt-4 pt-4 border-t border-gray-100">
          <p class="text-sm font-medium text-gray-900 mb-2">How to Donate</p>
          <ul class="space-y-1.5">
            {effectiveDeliveryMethods.map((method: string) => (
              <li class="flex items-center gap-2 text-sm text-gray-700">
                <svg class="w-4 h-4 text-green-600 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                {deliveryMethodLabels[method] || method}
              </li>
            ))}
          </ul>
          {effectiveDeliveryInstructions && (
            <div class="mt-2 text-sm text-gray-600 bg-gray-50 rounded-lg px-3 py-2 whitespace-pre-line">
              {effectiveDeliveryInstructions}
            </div>
          )}
        </div>
      )}

      {/* Shipping address */}
      {showShipping && (
        <div class="mt-4 pt-4 border-t border-gray-100">
          <p class="text-xs font-medium text-gray-500 mb-1">Ship donations to:</p>
          <div class="text-sm text-gray-700 bg-gray-50 rounded-lg px-3 py-2">
            {shippingAttn && <p class="font-medium">{shippingAttn}</p>}
            <p class="whitespace-pre-line">{shippingAddress}</p>
          </div>
        </div>
      )}
    </div>

    {/* Pledges section */}
    <div class="mb-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">Pledges ({need.pledgeCount})</h2>

      {pledgesWithComputed.length === 0 && (
        <div class="border border-dashed border-gray-300 rounded-lg p-8 text-center text-gray-500">
          <p class="mb-1">No pledges yet.</p>
          <p class="text-sm">Be the first to pledge gear for this need!</p>
        </div>
      )}

      <div class="space-y-4">
        {pledgesWithComputed.map((pledge) => (
          <div class="bg-white border border-gray-200 rounded-lg p-4">
            {/* Pledge header */}
            <div class="flex items-start justify-between gap-3 mb-2">
              <div>
                <span class="font-semibold text-gray-900 text-sm">{pledge.donorName}</span>
                <span class="text-xs text-gray-500 ml-2">{pledge.dateStr}</span>
              </div>
              <span class:list={["text-xs font-medium px-2 py-0.5 rounded-full border", pledge.badge]}>
                {pledge.label}
              </span>
            </div>

            {/* Pledge description */}
            <p class="text-sm text-gray-600 whitespace-pre-line mb-3">{pledge.description}</p>

            {/* Messages thread */}
            {(pledge.messagesWithDates.length > 0 || pledge.canMessage) && (
              <div class="border-t border-gray-100 pt-3 mt-3">
                {pledge.messagesWithDates.length > 0 && (
                  <Fragment>
                    <p class="text-xs font-medium text-gray-500 mb-2">Messages</p>
                    <div role="log" aria-label="Conversation messages" class="space-y-2 mb-3">
                      {pledge.messagesWithDates.map((msg) => (
                        <div class:list={[
                          "rounded-lg px-3 py-2 text-sm",
                          msg.isOrg ? "bg-green-50 border border-green-100 ml-4" : "bg-gray-50 border border-gray-100 mr-4",
                        ]}>
                          <div class="flex items-center gap-2 mb-1">
                            <span class:list={[
                              "text-xs font-medium",
                              msg.isOrg ? "text-green-700" : "text-gray-700",
                            ]}>
                              {msg.author}
                            </span>
                            {msg.isOrg && (
                              <span class="text-[10px] bg-green-100 text-green-700 px-1.5 py-0.5 rounded font-medium">
                                ORG
                              </span>
                            )}
                            <span class="text-xs text-gray-500 ml-auto">{msg.timeStr}</span>
                          </div>
                          <p class="text-gray-700">{msg.body}</p>
                        </div>
                      ))}
                    </div>
                  </Fragment>
                )}
                {pledge.canMessage && (
                  <form method="POST" action="/api/messages" class="flex flex-col sm:flex-row gap-2">
                    <input type="hidden" name="pledgeId" value={pledge.id} />
                    <input
                      type="text"
                      name="body"
                      required
                      maxlength="2000"
                      aria-label="Message text"
                      placeholder="Send a message..."
                      class="flex-1 border border-gray-300 rounded-lg px-3 py-1.5 text-sm focus:ring-2 focus:ring-[#2D4A2D]/30 focus:border-[#2D4A2D]"
                    />
                    <button
                      type="submit"
                      class="bg-[#2D4A2D] text-white px-3 py-1.5 rounded-lg text-sm hover:bg-[#1F361F] focus-visible:ring-2 focus-visible:ring-[#2D4A2D]/50 focus-visible:outline-none transition-colors"
                    >
                      Send
                    </button>
                  </form>
                )}
              </div>
            )}
          </div>
        ))}
      </div>
    </div>

    {/* Pledge form */}
    <div class="mb-8">
      {(need.status === "active" || need.status === "partially_fulfilled") ? (
        <>
          <h2 class="text-lg font-bold text-gray-900 mb-4">Make a Pledge</h2>
          <PledgeForm
            client:load
            needId={need.id}
            turnstileSiteKey={getEnv("TURNSTILE_SITE_KEY") || undefined}
            userEmail={session?.user?.email || undefined}
            userName={session?.user?.name || undefined}
            deliveryMethods={effectiveDeliveryMethods}
            deliveryInstructions={effectiveDeliveryInstructions}
            shippingAddress={showShipping ? shippingAddress : ""}
            shippingAttn={showShipping ? shippingAttn : ""}
          />
        </>
      ) : (
        <div class="border border-gray-200 rounded-lg p-6 text-center text-gray-500 text-sm">
          This need is no longer accepting pledges.
        </div>
      )}
    </div>
  </div>
  ) : (
    <div class="max-w-xl mx-auto text-center py-20">
      <p class="text-6xl font-bold text-[#2D4A2D]">404</p>
      <h1 class="text-2xl font-semibold mt-4 mb-2">Need not found</h1>
      <p class="text-gray-600 mb-6">
        This need is unavailable or may have been fulfilled, expired, or removed.
      </p>
      <a
        href="/"
        class="inline-block bg-[#2D4A2D] text-white px-6 py-2.5 rounded-lg hover:bg-[#1f351f] focus-visible:ring-2 focus-visible:ring-[#2D4A2D]/50 focus-visible:ring-offset-2 focus-visible:outline-none transition-colors text-sm font-medium"
      >
        Back to browse
      </a>
    </div>
  )}

  <script>
    const copyButton = document.getElementById('copy-need-link');
    const copyStatus = document.getElementById('copy-need-link-status');

    async function copyNeedLink() {
      const url = window.location.href;
      try {
        if (navigator.clipboard?.writeText) {
          await navigator.clipboard.writeText(url);
        } else {
          const input = document.createElement('input');
          input.value = url;
          document.body.appendChild(input);
          input.select();
          document.execCommand('copy');
          input.remove();
        }
        if (copyStatus) copyStatus.textContent = 'Link copied to clipboard.';
      } catch {
        if (copyStatus) copyStatus.textContent = 'Unable to copy link.';
      }
    }

    copyButton?.addEventListener('click', copyNeedLink);
  </script>
</Layout>
