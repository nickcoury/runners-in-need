---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact">
  <div class="max-w-3xl">
    <h1 class="text-3xl font-bold mb-6">Contact</h1>

    <div class="space-y-4 text-gray-600">
      <p>
        Runners In Need is an open project focused on connecting surplus running
        gear with those who need it. We'd love to hear from you.
      </p>

      <div class="bg-white rounded-lg border border-gray-200 p-6 space-y-3">
        <p>
          <span class="font-medium text-gray-900">General inquiries</span><br />
          <a href="mailto:hello@runnersinneed.org" class="text-[#2D4A2D] underline">hello@runnersinneed.org</a>
        </p>
        <p>
          <span class="font-medium text-gray-900">Privacy concerns</span><br />
          <a href="mailto:privacy@runnersinneed.org" class="text-[#2D4A2D] underline">privacy@runnersinneed.org</a>
        </p>
      </div>

      <p class="text-sm text-gray-500">
        This project is in active development. If you're interested in
        contributing or partnering, drop us a line.
      </p>
    </div>
  </div>
</Layout>
