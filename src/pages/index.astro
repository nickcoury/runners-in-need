---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import NeedCard from '../components/NeedCard.astro';
import MapView from '../components/MapView';
import { getDb, schema } from '../db';
import { inArray, desc } from 'drizzle-orm';

const db = getDb();
const needsWithOrg = await db.query.needs.findMany({
  where: inArray(schema.needs.status, ['active', 'partially_fulfilled']),
  with: {
    organization: true,
    pledges: true,
  },
  orderBy: [desc(schema.needs.createdAt)],
});

const allNeeds = needsWithOrg.map((n) => ({
  id: n.id,
  title: n.title,
  categoryTag: n.categoryTag,
  body: n.body,
  orgName: n.organization.name,
  location: n.location,
  lat: n.latitude,
  lng: n.longitude,
  extrasWelcome: n.extrasWelcome,
  status: n.status,
  expiresAt: n.expiresAt,
  pledgeCount: n.pledges.length,
}));

const urgentNeeds = allNeeds
  .filter((n) => {
    const days = Math.ceil((n.expiresAt.getTime() - Date.now()) / (1000 * 60 * 60 * 24));
    return days <= 30;
  })
  .slice(0, 3);

const mapNeeds = allNeeds
  .filter((n) => n.lat != null && n.lng != null)
  .map((n) => ({
    id: n.id,
    title: n.title,
    lat: n.lat!,
    lng: n.lng!,
  }));

const categories = [
  { tag: "all", label: "All", icon: "" },
  { tag: "shoes", label: "Shoes", icon: "👟" },
  { tag: "apparel", label: "Apparel", icon: "👕" },
  { tag: "accessories", label: "Accessories", icon: "🎽" },
  { tag: "other", label: "Other", icon: "📦" },
];
---

<Layout title="Home">
  {/* Compact hero */}
  <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-[#2D4A2D]">Runners In Need</h1>
      <p class="text-sm text-gray-600 mt-1">
        Connecting runners who have extra gear with organizations serving runners in need.
      </p>
    </div>
    <div class="flex gap-3 shrink-0">
      <a href="/post" class="bg-[#2D4A2D] text-white px-4 py-2 rounded-lg hover:bg-[#1F361F] text-sm font-medium transition-colors">
        Post a Need
      </a>
      <a href="/about" class="border border-gray-300 text-gray-700 px-4 py-2 rounded-lg hover:border-[#2D4A2D] hover:text-[#2D4A2D] text-sm font-medium transition-colors">
        Learn More
      </a>
    </div>
  </div>

  {/* Category filter pills + search area */}
  <div class="flex gap-2 mb-6 overflow-x-auto pb-2">
    {categories.map((cat, i) => (
      <button
        class:list={[
          "px-4 py-1.5 rounded-full text-sm font-medium whitespace-nowrap transition-colors",
          i === 0
            ? "bg-[#2D4A2D] text-white"
            : "bg-white text-gray-700 border border-gray-300 hover:border-[#2D4A2D] hover:text-[#2D4A2D]"
        ]}
      >
        {cat.icon} {cat.label}
      </button>
    ))}
  </div>

  {/* Main content: cards + sidebar */}
  <div class="flex gap-6">
    {/* Card grid */}
    <div class="flex-1 min-w-0">
      {allNeeds.length === 0 ? (
        <div class="text-center py-12 text-gray-500">
          <p class="text-lg font-medium mb-2">No needs posted yet</p>
          <p class="text-sm mb-4">Be the first to post a need for your running organization.</p>
          <a href="/post" class="inline-block bg-[#2D4A2D] text-white px-5 py-2 rounded-lg text-sm font-medium hover:bg-[#1F361F]">
            Post a Need
          </a>
        </div>
      ) : (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {allNeeds.map((need) => (
            <NeedCard {...need} />
          ))}
        </div>
      )}
    </div>

    {/* Sidebar — hidden on mobile */}
    <aside class="hidden lg:block w-72 shrink-0 space-y-6">
      {/* Map */}
      {mapNeeds.length > 0 && (
        <div>
          <h3 class="font-semibold text-sm text-gray-900 mb-2">NEEDS MAP</h3>
          <MapView client:visible needs={mapNeeds} />
        </div>
      )}

      {/* Urgent needs */}
      {urgentNeeds.length > 0 && (
        <div>
          <h3 class="font-semibold text-sm text-gray-900 mb-2">URGENT NEEDS</h3>
          <div class="space-y-2">
            {urgentNeeds.map((n) => {
              const daysLeft = Math.ceil((n.expiresAt.getTime() - Date.now()) / (1000*60*60*24));
              return (
                <a href={`/needs/${n.id}`} class="block text-sm hover:text-[#2D4A2D]">
                  <p class="font-medium text-gray-900 truncate">{n.title}</p>
                  <p class="text-xs text-amber-600">{daysLeft} days left</p>
                </a>
              );
            })}
          </div>
        </div>
      )}

      {/* How it works */}
      <div>
        <h3 class="font-semibold text-sm text-gray-900 mb-2">HOW IT WORKS</h3>
        <ol class="text-sm text-gray-600 space-y-2">
          <li class="flex gap-2">
            <span class="bg-[#2D4A2D] text-white w-5 h-5 rounded-full flex items-center justify-center text-xs shrink-0">1</span>
            <span>Organizers post what their runners need</span>
          </li>
          <li class="flex gap-2">
            <span class="bg-[#2D4A2D] text-white w-5 h-5 rounded-full flex items-center justify-center text-xs shrink-0">2</span>
            <span>Donors browse and pledge gear</span>
          </li>
          <li class="flex gap-2">
            <span class="bg-[#2D4A2D] text-white w-5 h-5 rounded-full flex items-center justify-center text-xs shrink-0">3</span>
            <span>Coordinate delivery or drop-off</span>
          </li>
          <li class="flex gap-2">
            <span class="bg-[#2D4A2D] text-white w-5 h-5 rounded-full flex items-center justify-center text-xs shrink-0">4</span>
            <span>Organizer confirms receipt</span>
          </li>
        </ol>
      </div>
    </aside>
  </div>
</Layout>
