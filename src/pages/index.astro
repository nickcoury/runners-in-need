---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import NeedsGrid from '../components/NeedsGrid';
import MapView from '../components/MapView';

// Extract approximate user location from Cloudflare geolocation headers
const cfLat = Astro.request.headers.get('cf-iplatitude');
const cfLng = Astro.request.headers.get('cf-iplongitude');
const userLat = cfLat ? parseFloat(cfLat) : null;
const userLng = cfLng ? parseFloat(cfLng) : null;

const errorParam = Astro.url.searchParams.get('error');
const deletedParam = Astro.url.searchParams.get('deleted');

const categories = [
  { tag: "all", label: "All", icon: "" },
  { tag: "shoes", label: "Shoes", icon: "👟" },
  { tag: "apparel", label: "Apparel", icon: "👕" },
  { tag: "accessories", label: "Accessories", icon: "🎽" },
  { tag: "other", label: "Other", icon: "📦" },
];
---

<Layout title="Home" description="Browse running gear needs and pledge donations to help runners in your community.">
  {deletedParam === '1' && (
    <div class="banner-alert bg-green-50 border border-green-200 rounded-lg px-4 py-3 mb-4 text-sm text-green-800 flex items-center justify-between" role="alert" aria-live="polite">
      <span>Your account has been deleted.</span>
      <button type="button" class="banner-close ml-3 text-green-600 hover:text-green-800" aria-label="Dismiss">&times;</button>
    </div>
  )}
  {errorParam === 'forbidden' && (
    <div class="banner-alert bg-red-50 border border-red-200 rounded-lg px-4 py-3 mb-4 text-sm text-red-800 flex items-center justify-between" role="alert" aria-live="polite">
      <span>You don't have permission to access that page.</span>
      <button type="button" class="banner-close ml-3 text-red-600 hover:text-red-800" aria-label="Dismiss">&times;</button>
    </div>
  )}

  {/* Compact hero */}
  <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-6">
    <div>
      <h1 class="text-2xl font-bold text-[#2D4A2D]">Runners In Need</h1>
      <p class="text-sm text-gray-600 mt-1">
        Connecting runners who have extra gear with organizations serving runners in need.
      </p>
    </div>
    <div class="flex gap-3 shrink-0">
      <a href="/post" class="bg-[#2D4A2D] text-white px-4 py-2 rounded-lg hover:bg-[#1F361F] text-sm font-medium transition-colors">
        Post a Need
      </a>
      <a href="/about" class="border border-gray-300 text-gray-700 px-4 py-2 rounded-lg hover:border-[#2D4A2D] hover:text-[#2D4A2D] text-sm font-medium transition-colors">
        Learn More
      </a>
    </div>
  </div>

  {/* Search + category filter pills */}
  <noscript>
    <p class="text-xs text-gray-500 mb-2">Search and filtering require JavaScript. All needs are shown below.</p>
  </noscript>
  <div class="mb-6 space-y-3">
    <div class="flex gap-2">
      <div class="relative flex-1">
        <input
          id="search-input"
          data-testid="search-input"
          type="text"
          aria-label="Search needs"
          placeholder="Search needs, items, locations..."
          class="w-full rounded-lg px-4 py-2 pr-8 text-sm text-gray-900 placeholder-gray-400 bg-white border border-gray-300 focus:ring-2 focus:ring-[#2D4A2D]/30 focus:border-[#2D4A2D]"
        />
        <button
          id="search-clear"
          data-testid="search-clear"
          type="button"
          aria-label="Clear search"
          class="hidden absolute right-2 top-1/2 -translate-y-1/2 text-gray-500 hover:text-gray-600 focus-visible:text-gray-700 focus-visible:ring-2 focus-visible:ring-[#2D4A2D]/30 focus-visible:outline-none rounded p-0.5"
        >
          <svg class="w-4 h-4" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      </div>
      <button
        id="location-btn"
        type="button"
        title="Sort by distance to your location"
        aria-label="Sort by distance to your location"
        class="shrink-0 flex items-center gap-1.5 px-3 py-2 rounded-lg text-sm font-medium border border-gray-300 bg-white text-gray-700 hover:border-[#2D4A2D] hover:text-[#2D4A2D] transition-colors"
      >
        <svg class="w-4 h-4" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <span class="hidden sm:inline" id="location-btn-text">Near me</span>
      </button>
    </div>
    <div id="location-indicator" class="hidden text-xs text-gray-500 flex items-center gap-1" aria-live="polite">
      <svg class="w-3 h-3" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      <span id="location-indicator-text">Sorted by distance</span>
      <button id="location-clear" class="ml-1 text-gray-500 hover:text-gray-600" aria-label="Clear location sort">&times;</button>
    </div>
    <div id="category-filters" role="group" aria-label="Filter by category" class="flex gap-2 overflow-x-auto pb-1">
      {categories.map((cat, i) => (
        <button
          data-testid="category-btn"
          data-category={cat.tag}
          aria-pressed={i === 0 ? "true" : "false"}
          class:list={[
            "category-btn px-4 py-1.5 rounded-full text-sm font-medium whitespace-nowrap transition-colors focus-visible:ring-2 focus-visible:ring-[#2D4A2D]/50 focus-visible:outline-none",
            i === 0
              ? "bg-[#2D4A2D] text-white"
              : "bg-white text-gray-700 border border-gray-300 hover:border-[#2D4A2D] hover:text-[#2D4A2D]"
          ]}
        >
          {cat.icon} {cat.label}
        </button>
      ))}
    </div>
  </div>

  {/* Desktop view toggle — list/map */}
  <div class="hidden lg:flex gap-1 mb-4 bg-gray-100 rounded-lg p-1 w-fit">
    <button
      id="desktop-tab-list"
      class="flex items-center gap-1.5 px-4 py-1.5 rounded-md text-sm font-medium bg-white text-[#2D4A2D] shadow-sm transition-all"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
      </svg>
      List
    </button>
    <button
      id="desktop-tab-map"
      class="flex items-center gap-1.5 px-4 py-1.5 rounded-md text-sm font-medium text-gray-500 transition-all"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l5.447 2.724A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
      </svg>
      Map
    </button>
  </div>

  {/* Main content: cards + sidebar */}
  <div id="desktop-list-view" class="flex gap-6 pb-16 lg:pb-0">
    {/* Card grid — hidden on mobile when map tab active */}
    <div id="listings-view" class="flex-1 min-w-0">
      <NeedsGrid client:only="react" />
    </div>

    {/* Fullscreen map — hidden by default on mobile, toggled by bottom nav */}
    <div id="map-view" class="hidden lg:hidden fixed inset-0 top-[52px] bottom-[56px] z-40 bg-white">
      <MapView client:only="react" fullscreen />
    </div>

    {/* Sidebar — desktop only */}
    <aside class="hidden lg:block w-72 shrink-0 space-y-6">
      <div>
        <h2 class="font-semibold text-sm text-gray-900 mb-2">HOW IT WORKS</h2>
        <ol class="text-sm text-gray-600 space-y-2">
          <li class="flex gap-2">
            <span class="bg-[#2D4A2D] text-white w-5 h-5 rounded-full flex items-center justify-center text-xs shrink-0">1</span>
            <span>Organizers post what their runners need</span>
          </li>
          <li class="flex gap-2">
            <span class="bg-[#2D4A2D] text-white w-5 h-5 rounded-full flex items-center justify-center text-xs shrink-0">2</span>
            <span>Donors browse and pledge gear</span>
          </li>
          <li class="flex gap-2">
            <span class="bg-[#2D4A2D] text-white w-5 h-5 rounded-full flex items-center justify-center text-xs shrink-0">3</span>
            <span>Coordinate delivery or drop-off</span>
          </li>
          <li class="flex gap-2">
            <span class="bg-[#2D4A2D] text-white w-5 h-5 rounded-full flex items-center justify-center text-xs shrink-0">4</span>
            <span>Organizer confirms receipt</span>
          </li>
        </ol>
      </div>
    </aside>
  </div>

  {/* Become an organizer CTA */}
  <div class="text-center py-10 mt-6 border-t border-gray-200">
    <p class="text-gray-700 text-sm mb-3">Run a program that needs gear? <a href="/become-organizer" class="text-[#2D4A2D] font-medium hover:underline">Apply to become an organizer.</a></p>
  </div>

  {/* Desktop expanded map view — hidden by default, shown when Map tab clicked */}
  <div id="desktop-map-view" class="hidden rounded-lg overflow-hidden" style="height: calc(100vh - 240px); min-height: 400px;">
    <MapView client:only="react" fullscreen />
  </div>

  {/* Mobile bottom nav — toggle between listings and map */}
  <nav id="mobile-bottom-nav" aria-label="View toggle" class="lg:hidden fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 z-50 flex">
    <button
      id="tab-listings"
      aria-label="Switch to listings view"
      aria-pressed="true"
      class="flex-1 py-3 text-center text-sm font-medium text-[#2D4A2D] border-t-2 border-[#2D4A2D]"
    >
      <svg class="w-5 h-5 mx-auto mb-0.5" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
      </svg>
      Listings
    </button>
    <button
      id="tab-map"
      aria-label="Switch to map view"
      aria-pressed="false"
      class="flex-1 py-3 text-center text-sm font-medium text-gray-500 border-t-2 border-transparent"
    >
      <svg class="w-5 h-5 mx-auto mb-0.5" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l5.447 2.724A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
      </svg>
      Map
    </button>
  </nav>

  <div id="cf-location" class="hidden" data-lat={userLat ?? ''} data-lng={userLng ?? ''}></div>

  <script>
    import '../scripts/browse';
  </script>
</Layout>
