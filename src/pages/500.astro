---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Server Error">
  <div class="max-w-xl mx-auto text-center py-20">
    <p class="text-6xl font-bold text-[#2D4A2D]">500</p>
    <h1 class="text-2xl font-semibold mt-4 mb-2">Something went wrong</h1>
    <p class="text-gray-600 mb-6">
      We hit an unexpected error. This is on our end, not yours. Try refreshing the page or come back in a few minutes.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
      <a
        href="/"
        class="inline-block bg-[#2D4A2D] text-white px-6 py-2.5 rounded-lg hover:bg-[#1f351f] transition-colors text-sm font-medium"
      >
        Back to Home
      </a>
      <button
        onclick="location.reload()"
        class="inline-block border border-gray-300 text-gray-700 px-6 py-2.5 rounded-lg hover:border-[#2D4A2D] hover:text-[#2D4A2D] transition-colors text-sm font-medium cursor-pointer"
      >
        Try Again
      </button>
    </div>
    <p class="text-sm text-gray-400 mt-8">
      If this keeps happening, <a href="/contact" class="underline hover:text-[#2D4A2D]">let us know</a>.
    </p>
  </div>
</Layout>
