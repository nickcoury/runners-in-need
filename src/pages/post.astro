---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import NeedForm from '../components/NeedForm';
import { getDb, schema } from '../db';
import { eq } from 'drizzle-orm';

// Session is set by middleware (which redirects if not authenticated)
const session = Astro.locals.session;
if (!session?.user) {
  return Astro.redirect('/auth/signin?callbackUrl=/post');
}

const db = getDb();
const user = await db.query.users.findFirst({
  where: eq(schema.users.id, session.user.id),
});

const orgId = user?.orgId || '';
const isOrganizer = user?.role === 'organizer' && !!orgId;
---

<Layout title="Post a Need">
  <div class="max-w-3xl">
    <h1 class="text-3xl font-bold mb-3">Post a Need</h1>
    <p class="text-gray-600 mb-8">
      Describe what your runners need. Be specific about sizes, quantities, and
      condition &mdash; it helps donors match the right gear to your group.
    </p>

    {!isOrganizer ? (
      <div class="bg-amber-50 border border-amber-200 rounded-lg px-4 py-3 mb-6 text-sm text-amber-800">
        Only verified organizers can post needs. <a href="/become-organizer" class="underline font-medium">Request organizer access</a> to get started.
      </div>
    ) : (
      <NeedForm client:load orgId={orgId} />
    )}
  </div>
</Layout>
