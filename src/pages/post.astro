---
export const prerender = false;

// TODO: This page requires authentication. Redirect unauthenticated users to /auth/signin.
// TODO: Get orgId from the authenticated user's session
import Layout from '../layouts/Layout.astro';
import NeedForm from '../components/NeedForm';

// Placeholder until auth is wired up
const orgId = "demo-org";
---

<Layout title="Post a Need">
  <div class="max-w-3xl">
    <h1 class="text-3xl font-bold mb-3">Post a Need</h1>
    <p class="text-gray-600 mb-8">
      Describe what your runners need. Be specific about sizes, quantities, and
      condition &mdash; it helps donors match the right gear to your group.
    </p>

    <div class="bg-amber-50 border border-amber-200 rounded-lg px-4 py-3 mb-6 text-sm text-amber-800">
      Sign-in is required to post needs. This is a preview of the form.
    </div>

    <NeedForm client:load orgId={orgId} />
  </div>
</Layout>
