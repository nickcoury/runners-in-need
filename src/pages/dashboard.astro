---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import DashboardTabs from '../components/DashboardTabs';
import type { DashboardNeed, DashboardPledge } from '../components/dashboard/types';
import { getDb, schema } from '../db';
import { eq } from 'drizzle-orm';

// Session is set by middleware (which redirects if not authenticated)
const session = Astro.locals.session;
if (!session?.user) {
  return Astro.redirect('/auth/signin?callbackUrl=/dashboard');
}

const db = getDb();
const userId = session.user.id!;
const userRole = session.user.role || 'donor';

// Get the user's org if they're an organizer
const user = await db.query.users.findFirst({
  where: eq(schema.users.id, userId),
  with: { organization: true },
});

const orgName = user?.organization?.name || '';
const orgEmail = session.user.email || '';
const orgLocation = user?.organization?.location || '';
const orgDescription = user?.organization?.description || '';
const orgId = user?.orgId || '';
const orgShippingAddress = user?.organization?.shippingAddress || '';
const orgShippingAttn = user?.organization?.shippingAttn || '';
const orgShowShippingAddress = user?.organization?.showShippingAddress || false;
const orgPledgeDriveInterest = user?.organization?.pledgeDriveInterest || false;

let needs: DashboardNeed[] = [];

let pledges: DashboardPledge[] = [];

if (userRole === 'organizer' && user?.orgId) {
  // Organizer: show their org's needs with pledge counts
  const orgNeeds = await db.query.needs.findMany({
    where: eq(schema.needs.orgId, user.orgId),
    with: { pledges: true },
  });
  needs = orgNeeds.map((n) => {
    const daysLeft = Math.max(0, Math.ceil((n.expiresAt.getTime() - Date.now()) / (1000 * 60 * 60 * 24)));
    return {
      id: n.id,
      title: n.title,
      categoryTag: n.categoryTag,
      status: n.status,
      pledgeCount: n.pledges.length,
      daysLeft,
      location: n.location,
    };
  });

  // Build pledges array from already-loaded orgNeeds data
  pledges = orgNeeds.flatMap((n) =>
    n.pledges.map((p) => ({
      id: p.id,
      needId: p.needId,
      needTitle: n.title,
      donorName: p.donorName || 'Anonymous',
      donorEmail: p.donorEmail,
      description: p.description,
      status: p.status,
      createdAt: p.createdAt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }),
    }))
  );
} else {
  // Donor: show their pledges
  const donorPledges = await db.query.pledges.findMany({
    where: eq(schema.pledges.donorId, userId),
    with: { need: true },
  });
  pledges = donorPledges.map((p) => ({
    id: p.id,
    needId: p.needId,
    needTitle: p.need.title,
    donorName: p.donorName || session.user!.name || 'You',
    donorEmail: p.donorEmail,
    description: p.description,
    status: p.status,
    createdAt: p.createdAt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }),
  }));
}
---

<Layout title="Dashboard">
  <h1 class="text-3xl font-bold mb-2">Dashboard</h1>
  <p class="text-gray-500 text-sm mb-6">
    {orgName ? `${orgName} — ` : ''}Manage your {userRole === 'organizer' ? 'needs, pledges' : 'pledges'}, and account.
  </p>

  <DashboardTabs
    client:load
    needs={needs}
    pledges={pledges}
    orgName={orgName}
    orgEmail={orgEmail}
    orgLocation={orgLocation}
    orgDescription={orgDescription}
    orgId={orgId}
    orgShippingAddress={orgShippingAddress}
    orgShippingAttn={orgShippingAttn}
    orgShowShippingAddress={orgShowShippingAddress}
    orgPledgeDriveInterest={orgPledgeDriveInterest}
    userRole={userRole}
  />
</Layout>
