---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import { actions } from 'astro:actions';
import { getDb, schema } from '../db';
import { eq } from 'drizzle-orm';

const actionResult = Astro.getActionResult(actions.submitOrganizerRequest);
const session = Astro.locals.session;
const isSignedIn = !!session?.user?.id;

let existingRequest = null;
let isAlreadyOrganizer = false;
let reapplyDate: string | null = null;

if (isSignedIn) {
  const db = getDb();
  const user = await db.query.users.findFirst({
    where: eq(schema.users.id, session.user.id),
  });

  if (user?.role === 'organizer') {
    isAlreadyOrganizer = true;
  } else {
    const request = await db.query.organizerRequests.findFirst({
      where: eq(schema.organizerRequests.userId, session.user.id),
    });

    if (request?.status === 'denied' && request.reviewedAt) {
      const twelveMonthsLater = new Date(request.reviewedAt);
      twelveMonthsLater.setMonth(twelveMonthsLater.getMonth() + 12);

      if (new Date() >= twelveMonthsLater) {
        // Cooldown expired — delete old request so they can reapply
        await db.delete(schema.organizerRequests).where(eq(schema.organizerRequests.id, request.id));
        // existingRequest stays null → form will show
      } else {
        existingRequest = request;
        reapplyDate = twelveMonthsLater.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
      }
    } else {
      existingRequest = request ?? null;
    }
  }
}
---

<Layout title="Become an Organizer">
  <div class="max-w-2xl mx-auto">
    <h1 class="text-3xl font-bold mb-3">Become an Organizer</h1>
    <p class="text-gray-600 mb-8">
      Organizers can post needs on behalf of their running program.
      We verify each request to ensure legitimacy.
    </p>

    {!isSignedIn ? (
      <div class="bg-amber-50 border border-amber-200 rounded-lg px-4 py-3 text-sm text-amber-800">
        Please <a href="/auth/signin?callbackUrl=/become-organizer" class="underline font-medium">sign in</a> first, then come back to submit your request.
      </div>
    ) : isAlreadyOrganizer ? (
      <div class="bg-green-50 border border-green-200 rounded-lg px-4 py-3 text-sm text-green-800">
        You're already a verified organizer! <a href="/post" class="underline font-medium">Post a need</a> or visit your <a href="/dashboard" class="underline font-medium">dashboard</a>.
      </div>
    ) : existingRequest ? (
      <div class:list={[
        "rounded-lg px-4 py-3 text-sm border",
        existingRequest.status === 'pending' ? "bg-blue-50 border-blue-200 text-blue-800" :
        existingRequest.status === 'approved' ? "bg-green-50 border-green-200 text-green-800" :
        "bg-red-50 border-red-200 text-red-800"
      ]}>
        {existingRequest.status === 'pending' && (
          <p>Your request for <strong>{existingRequest.orgName}</strong> is pending review. We'll get back to you soon.</p>
        )}
        {existingRequest.status === 'approved' && (
          <p>Your request has been approved! Visit your <a href="/dashboard" class="underline font-medium">dashboard</a> to get started.</p>
        )}
        {existingRequest.status === 'denied' && (
          <p>Your request was not approved. {reapplyDate ? `You may reapply after ${reapplyDate}.` : ''} Please <a href="/contact" class="underline font-medium">contact us</a> if you have questions.</p>
        )}
      </div>
    ) : actionResult && !actionResult.error ? (
      <div class="bg-green-50 border border-green-200 rounded-lg px-4 py-3 text-sm text-green-800">
        Your request has been submitted! We'll review it and get back to you soon.
      </div>
    ) : (
      <form method="POST" action="/_actions/submitOrganizerRequest" class="space-y-6">
        {actionResult?.error && (
          <div class="bg-red-50 border border-red-200 rounded-lg px-4 py-3 text-sm text-red-800">
            {actionResult.error.code === 'BAD_REQUEST'
              ? 'Please check the form fields and try again.'
              : 'Something went wrong. Please try again.'}
          </div>
        )}
        <!-- Honeypot field — hidden from real users, bots will fill it in -->
        <div aria-hidden="true" style="position:absolute;left:-9999px;top:-9999px;">
          <label for="website">Website</label>
          <input id="website" name="website" type="text" tabindex="-1" autocomplete="off" />
        </div>

        <div>
          <label for="orgName" class="block text-sm font-medium text-gray-700 mb-1">
            Organization Name
          </label>
          <input
            id="orgName"
            name="orgName"
            type="text"
            required
            minlength="2"
            maxlength="200"
            placeholder="e.g., Wilson High School Cross Country"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-[#2D4A2D]/30 focus:border-[#2D4A2D]"
          />
        </div>

        <div>
          <label for="orgDescription" class="block text-sm font-medium text-gray-700 mb-1">
            Tell us about your organization
          </label>
          <textarea
            id="orgDescription"
            name="orgDescription"
            required
            rows="4"
            minlength="10"
            maxlength="2000"
            placeholder="What does your running program do? How many runners do you serve? What kinds of gear do you typically need?"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-[#2D4A2D]/30 focus:border-[#2D4A2D]"
          />
        </div>

        <div>
          <label for="orgUrl" class="block text-sm font-medium text-gray-700 mb-1">
            Website or social media link <span class="text-gray-400 font-normal">(optional)</span>
          </label>
          <input
            id="orgUrl"
            name="orgUrl"
            type="url"
            placeholder="https://..."
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-[#2D4A2D]/30 focus:border-[#2D4A2D]"
          />
        </div>

        <button
          type="submit"
          class="bg-[#2D4A2D] text-white px-6 py-2 rounded-lg hover:bg-[#1F361F] text-sm font-medium transition-colors"
        >
          Submit Request
        </button>
      </form>
    )}
  </div>
</Layout>
