---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import { getDb, schema } from '../db';
import { eq } from 'drizzle-orm';

const session = Astro.locals.session;
if (!session?.user) {
  return Astro.redirect('/auth/signin?callbackUrl=/profile');
}

const db = getDb();
const userId = session.user.id!;
const userRole = session.user.role || 'donor';

const user = await db.query.users.findFirst({
  where: eq(schema.users.id, userId),
  with: { organization: true },
});

if (!user) {
  return Astro.redirect('/auth/signin');
}

// Get pledge count
const userPledges = await db.query.pledges.findMany({
  where: eq(schema.pledges.donorId, userId),
  columns: { id: true, status: true },
});

// Get org needs count if organizer
let needsCount = 0;
if (userRole === 'organizer' && user.orgId) {
  const orgNeeds = await db.query.needs.findMany({
    where: eq(schema.needs.orgId, user.orgId),
    columns: { id: true },
  });
  needsCount = orgNeeds.length;
}

const memberSince = user.createdAt.toLocaleDateString('en-US', {
  month: 'long',
  year: 'numeric',
});

const totalPledges = userPledges.length;
const deliveredPledges = userPledges.filter(p => p.status === 'delivered').length;
const image = session.user.image || null;
const initials = user.name.split(' ').map((w: string) => w[0]).join('').toUpperCase().slice(0, 2);

const isOrganizer = userRole === 'organizer' && user.orgId && user.organization;
---

<Layout title="Profile">
  <div class="max-w-2xl mx-auto">
    <h1 class="text-2xl font-bold mb-6">Your Profile</h1>

    {/* Profile header card */}
    <div class="bg-white border border-gray-200 rounded-lg p-6 mb-6">
      <div class="flex items-start gap-4">
        <div class="w-16 h-16 rounded-full bg-[#2D4A2D] text-white flex items-center justify-center text-xl font-bold shrink-0 overflow-hidden">
          {image ? (
            <img src={image} alt={user.name} class="w-full h-full object-cover" referrerpolicy="no-referrer" />
          ) : (
            <span>{initials}</span>
          )}
        </div>
        <div class="flex-1 min-w-0">
          <h2 id="profile-name" class="text-xl font-semibold text-gray-900">{user.name}</h2>
          <p class="text-sm text-gray-500">{user.email}</p>
          <div class="flex items-center gap-3 mt-2">
            <span class="inline-block text-xs capitalize bg-[#2D4A2D]/10 text-[#2D4A2D] px-2.5 py-1 rounded-full font-medium">
              {userRole}
            </span>
            <span class="text-xs text-gray-400">Member since {memberSince}</span>
          </div>
        </div>
      </div>
    </div>

    {/* Stats */}
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 mb-6">
      {userRole === 'organizer' && (
        <div class="bg-white border border-gray-200 rounded-lg p-4 text-center">
          <p class="text-2xl font-bold text-[#2D4A2D]">{needsCount}</p>
          <p class="text-xs text-gray-500 mt-1">Needs Posted</p>
        </div>
      )}
      <div class="bg-white border border-gray-200 rounded-lg p-4 text-center">
        <p class="text-2xl font-bold text-[#2D4A2D]">{totalPledges}</p>
        <p class="text-xs text-gray-500 mt-1">Total Pledges</p>
      </div>
      <div class="bg-white border border-gray-200 rounded-lg p-4 text-center">
        <p class="text-2xl font-bold text-[#2D4A2D]">{deliveredPledges}</p>
        <p class="text-xs text-gray-500 mt-1">Delivered</p>
      </div>
    </div>

    {/* Tabs (only shown for organizers) */}
    {isOrganizer && (
      <div class="mb-6">
        <div class="flex border-b border-gray-200" role="tablist">
          <button
            data-tab="profile"
            role="tab"
            aria-selected="true"
            aria-controls="tab-profile"
            id="tab-btn-profile"
            class="tab-btn px-4 py-2.5 text-sm font-medium border-b-2 border-[#2D4A2D] text-[#2D4A2D] -mb-px"
          >
            Profile
          </button>
          <button
            data-tab="organization"
            role="tab"
            aria-selected="false"
            aria-controls="tab-organization"
            id="tab-btn-organization"
            class="tab-btn px-4 py-2.5 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 -mb-px"
          >
            Organization
          </button>
        </div>
      </div>
    )}

    {/* Profile tab content */}
    <div id="tab-profile" role="tabpanel" aria-labelledby="tab-btn-profile">
      <div class="bg-white border border-gray-200 rounded-lg p-6 mb-6">
        <h3 class="text-sm font-semibold text-gray-900 mb-4">Edit Profile</h3>

        <form id="profile-form" class="space-y-4">
          <div>
            <label for="name" class="block text-sm font-medium text-gray-700 mb-1">
              Display Name
            </label>
            <input
              type="text"
              id="name"
              name="name"
              value={user.name}
              required
              minlength="1"
              maxlength="100"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-[#2D4A2D]/30 focus:border-[#2D4A2D]"
            />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              Email
            </label>
            <input
              type="email"
              value={user.email}
              disabled
              class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm bg-gray-50 text-gray-500"
            />
            <p class="text-xs text-gray-400 mt-1">Managed by your sign-in provider</p>
          </div>

          <div class="flex items-center gap-3">
            <button
              type="submit"
              id="save-btn"
              class="bg-[#2D4A2D] text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-[#1F361F] transition-colors"
            >
              Save Changes
            </button>
            <span id="save-status" class="text-sm text-green-600 hidden">Saved!</span>
            <span id="save-error" class="text-sm text-red-600 hidden"></span>
          </div>
        </form>
      </div>
    </div>

    {/* Organization tab content (organizers only) */}
    {isOrganizer && (
      <div id="tab-organization" class="hidden" role="tabpanel" aria-labelledby="tab-btn-organization">
        <div class="bg-white border border-gray-200 rounded-lg p-6 mb-6">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-sm font-semibold text-gray-900">Organization Details</h3>
            <a href={`/org/${user.orgId}`} class="text-xs text-[#2D4A2D] hover:underline">View public page &rarr;</a>
          </div>
          <form id="org-form" class="space-y-4">
            <input type="hidden" name="orgId" value={user.orgId} />

            <div>
              <label for="org-name" class="block text-sm font-medium text-gray-700 mb-1">
                Organization Name
              </label>
              <input
                type="text"
                id="org-name"
                name="name"
                value={user.organization.name}
                required
                minlength="2"
                maxlength="200"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-[#2D4A2D]/30 focus:border-[#2D4A2D]"
              />
            </div>

            <div>
              <label for="org-location" class="block text-sm font-medium text-gray-700 mb-1">
                Location <span class="text-gray-400 font-normal">(City, State)</span>
              </label>
              <input
                type="text"
                id="org-location"
                name="location"
                value={user.organization.location}
                required
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-[#2D4A2D]/30 focus:border-[#2D4A2D]"
              />
            </div>

            <div>
              <label for="org-description" class="block text-sm font-medium text-gray-700 mb-1">
                Description
              </label>
              <textarea
                id="org-description"
                name="description"
                rows="3"
                maxlength="2000"
                class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-[#2D4A2D]/30 focus:border-[#2D4A2D]"
              >{user.organization.description || ''}</textarea>
            </div>

            <div class="flex items-center gap-3">
              <button
                type="submit"
                id="org-save-btn"
                class="bg-[#2D4A2D] text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-[#1F361F] transition-colors"
              >
                Save Organization
              </button>
              <span id="org-save-status" class="text-sm text-green-600 hidden">Saved!</span>
            </div>
          </form>
        </div>
      </div>
    )}

    {/* Danger zone */}
    <div class="bg-white border border-gray-200 rounded-lg p-6">
      <h3 class="text-sm font-semibold text-gray-900 mb-4">Account</h3>
      <div class="flex gap-3">
        <button
          id="sign-out-profile-btn"
          class="border border-red-300 text-red-600 px-4 py-2 rounded-lg text-sm font-medium hover:bg-red-50 transition-colors"
        >
          Sign Out
        </button>
        <button
          id="delete-account-btn"
          class="border border-red-300 text-red-600 px-4 py-2 rounded-lg text-sm font-medium hover:bg-red-50 transition-colors"
        >
          Delete Account
        </button>
      </div>
    </div>
  </div>

  <script>
    // Tab switching
    const tabBtns = document.querySelectorAll('.tab-btn');
    tabBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const tab = (btn as HTMLElement).dataset.tab!;
        // Update button styles and aria-selected
        tabBtns.forEach((b) => {
          b.classList.remove('border-[#2D4A2D]', 'text-[#2D4A2D]');
          b.classList.add('border-transparent', 'text-gray-500');
          b.setAttribute('aria-selected', 'false');
        });
        btn.classList.add('border-[#2D4A2D]', 'text-[#2D4A2D]');
        btn.classList.remove('border-transparent', 'text-gray-500');
        btn.setAttribute('aria-selected', 'true');
        // Show/hide tab content
        document.getElementById('tab-profile')?.classList.toggle('hidden', tab !== 'profile');
        document.getElementById('tab-organization')?.classList.toggle('hidden', tab !== 'organization');
      });
    });

    // Profile name update
    const profileForm = document.getElementById('profile-form') as HTMLFormElement;
    profileForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const saveBtn = document.getElementById('save-btn') as HTMLButtonElement;
      const saveStatus = document.getElementById('save-status')!;
      const saveError = document.getElementById('save-error')!;

      saveBtn.disabled = true;
      saveBtn.textContent = 'Saving...';
      saveStatus.classList.add('hidden');
      saveError.classList.add('hidden');

      try {
        const formData = new FormData(profileForm);
        const res = await fetch('/api/user/update', {
          method: 'POST',
          body: formData,
        });

        if (res.ok) {
          saveStatus.classList.remove('hidden');
          // Update the name display on the page
          const nameEl = document.getElementById('profile-name');
          if (nameEl) nameEl.textContent = formData.get('name') as string;
          setTimeout(() => saveStatus.classList.add('hidden'), 3000);
        } else {
          const text = await res.text();
          saveError.textContent = text || 'Failed to save';
          saveError.classList.remove('hidden');
        }
      } catch {
        saveError.textContent = 'Network error';
        saveError.classList.remove('hidden');
      } finally {
        saveBtn.disabled = false;
        saveBtn.textContent = 'Save Changes';
      }
    });

    // Org update
    const orgForm = document.getElementById('org-form') as HTMLFormElement;
    orgForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('org-save-btn') as HTMLButtonElement;
      const status = document.getElementById('org-save-status')!;

      btn.disabled = true;
      btn.textContent = 'Saving...';

      try {
        const res = await fetch('/api/org/update', {
          method: 'POST',
          body: new FormData(orgForm),
        });

        if (res.ok) {
          status.classList.remove('hidden');
          setTimeout(() => status.classList.add('hidden'), 3000);
        }
      } finally {
        btn.disabled = false;
        btn.textContent = 'Save Organization';
      }
    });

    // Delete account
    document.getElementById('delete-account-btn')?.addEventListener('click', async () => {
      if (!confirm('Are you sure you want to delete your account? This action cannot be undone.')) return;
      if (!confirm('This will permanently delete your account, withdraw your pledges, and remove your data. Continue?')) return;
      try {
        const res = await fetch('/api/user/delete', { method: 'POST' });
        if (res.ok) {
          window.location.href = '/';
        } else {
          alert('Failed to delete account. Please try again.');
        }
      } catch {
        alert('Network error. Please try again.');
      }
    });

    // Sign out — uses global handler defined in Layout
    document.getElementById('sign-out-profile-btn')?.addEventListener('click', () => {
      (window as any).signOut?.();
    });
  </script>
</Layout>
