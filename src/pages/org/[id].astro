---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import { getDb, schema } from "../../db";
import { eq, and, inArray } from "drizzle-orm";
import { categoryStyles, categoryLabels } from "../../lib/constants";

const { id } = Astro.params;
const db = getDb();

const org = await db.query.organizations.findFirst({
  where: eq(schema.organizations.id, id!),
});

if (!org) {
  return Astro.redirect("/404");
}

const activeNeeds = await db.query.needs.findMany({
  where: and(
    eq(schema.needs.orgId, org.id),
    inArray(schema.needs.status, ["active", "partially_fulfilled"]),
  ),
  with: {
    pledges: { columns: { id: true } },
  },
  orderBy: (needs, { desc }) => [desc(needs.createdAt)],
});

const msPerDay = 1000 * 60 * 60 * 24;

const needsWithComputed = activeNeeds.map((n) => {
  const daysLeft = Math.ceil((n.expiresAt.getTime() - Date.now()) / msPerDay);
  const expiryText = daysLeft <= 0 ? "Expired" : `${daysLeft} days left`;
  const expiryClass = daysLeft <= 14 && daysLeft > 0 ? "text-amber-600 font-medium" : daysLeft <= 0 ? "text-red-600 font-medium" : "text-gray-500";
  return {
    id: n.id,
    title: n.title,
    categoryTag: n.categoryTag,
    categoryLabel: categoryLabels[n.categoryTag] || "Other",
    categoryStyle: categoryStyles[n.categoryTag] || categoryStyles.other,
    body: n.body,
    location: n.location,
    pledgeCount: n.pledges.length,
    expiryText,
    expiryClass,
    createdAt: n.createdAt.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" }),
  };
});

const memberSince = org.createdAt.toLocaleDateString("en-US", { month: "long", year: "numeric" });
---

<Layout title={org.name} description={`${org.name} — Organization on Runners In Need`} ogType="profile">
  <div class="max-w-3xl mx-auto">
    <a href="/" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-[#2D4A2D] mb-4">
      &larr; Back to browse
    </a>

    {/* Org header */}
    <div class="bg-white border border-gray-200 rounded-lg p-4 sm:p-6 mb-6">
      <div class="flex items-start gap-3">
        <div class="w-12 h-12 rounded-full bg-[#2D4A2D] text-white flex items-center justify-center text-lg font-bold shrink-0">
          {org.name.charAt(0).toUpperCase()}
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex flex-wrap items-center gap-2">
            <h1 class="text-2xl font-bold text-gray-900 break-words">{org.name}</h1>
            {org.verified && (
              <span class="text-xs bg-green-50 text-green-700 px-2 py-0.5 rounded-full border border-green-200 font-medium">Verified</span>
            )}
          </div>
          <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-gray-500 mt-1">
            <span>{org.location}</span>
            <span>&middot;</span>
            <span>Member since {memberSince}</span>
          </div>
        </div>
      </div>

      {org.description && (
        <p class="text-sm text-gray-700 leading-relaxed mt-4 whitespace-pre-line">{org.description}</p>
      )}
    </div>

    {/* Active needs */}
    <h2 class="text-lg font-bold text-gray-900 mb-4">Active Needs ({needsWithComputed.length})</h2>

    {needsWithComputed.length === 0 && (
      <div class="border border-dashed border-gray-300 rounded-lg p-8 text-center text-gray-500">
        <p>This organization has no active needs right now.</p>
      </div>
    )}

    <div class="space-y-4 mb-8">
      {needsWithComputed.map((need) => (
        <a href={`/needs/${need.id}`} class="block bg-white border border-gray-200 rounded-lg p-4 hover:border-[#2D4A2D]/30 hover:shadow-sm transition-all">
          <div class="flex flex-wrap items-center gap-2 mb-2">
            <span class:list={["text-xs font-medium px-2.5 py-1 rounded-full", need.categoryStyle]}>
              {need.categoryLabel}
            </span>
            <span class:list={["text-xs ml-auto", need.expiryClass]}>
              {need.expiryText}
            </span>
          </div>
          <h3 class="font-semibold text-gray-900 mb-1">{need.title}</h3>
          <p class="text-sm text-gray-600 line-clamp-2 mb-2">{need.body}</p>
          <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-gray-500">
            <span>{need.location}</span>
            <span>{need.pledgeCount === 1 ? "1 pledge" : `${need.pledgeCount} pledges`}</span>
            <span>Posted {need.createdAt}</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>
