---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { getDb, schema } from '../../db';
import { eq, desc, inArray } from 'drizzle-orm';

// Auth is checked by middleware, but defense-in-depth: verify admin role
const session = Astro.locals.session;
if (!session?.user || session.user.role !== 'admin') {
  return Astro.redirect('/?error=forbidden');
}

const db = getDb();
const requests = await db.query.organizerRequests.findMany({
  orderBy: [desc(schema.organizerRequests.createdAt)],
});

// Batch-fetch all users referenced by requests
const userIds = [...new Set(requests.map((r) => r.userId))];
const users = userIds.length > 0
  ? await db.query.users.findMany({ where: inArray(schema.users.id, userIds) })
  : [];
const usersById = new Map(users.map((u) => [u.id, u]));

const requestsWithUsers = requests.map((r) => {
  const user = usersById.get(r.userId);
  return {
    ...r,
    userName: user?.name || 'Unknown',
    userEmail: user?.email || '',
    createdAtStr: r.createdAt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }),
  };
});

const pending = requestsWithUsers.filter((r) => r.status === 'pending');
const reviewed = requestsWithUsers.filter((r) => r.status !== 'pending');
---

<Layout title="Organizer Requests">
  <h1 class="text-3xl font-bold mb-2">Organizer Requests</h1>
  <p class="text-gray-500 text-sm mb-6">Review and approve organizations requesting to post needs.</p>

  <div class="mb-6 text-sm">
    <a href="/admin/drives" class="text-[#2D4A2D] hover:underline focus-visible:underline focus-visible:outline-none">View Pledge Drives &rarr;</a>
  </div>

  {pending.length === 0 ? (
    <div class="border border-dashed border-gray-300 rounded-lg p-8 text-center text-gray-500 mb-8">
      <p>No pending requests.</p>
    </div>
  ) : (
    <div class="space-y-4 mb-8">
      <h2 class="text-lg font-semibold">Pending ({pending.length})</h2>
      {pending.map((req) => (
        <div class="bg-white border border-gray-200 rounded-lg p-5">
          <div class="flex items-start justify-between gap-4 mb-3">
            <div>
              <h3 class="font-semibold text-gray-900">{req.orgName}</h3>
              <p class="text-xs text-gray-500">{req.userName} ({req.userEmail}) &middot; {req.createdAtStr}</p>
            </div>
            <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-amber-50 text-amber-700 border border-amber-200">
              Pending
            </span>
          </div>
          <p class="text-sm text-gray-600 mb-3">{req.orgDescription}</p>
          {req.orgUrl && (
            <p class="text-sm text-gray-500 mb-3">
              URL: <a href={req.orgUrl} target="_blank" rel="noopener noreferrer" class="text-[#2D4A2D] underline">{req.orgUrl}</a>
            </p>
          )}
          <div class="flex gap-2">
            <form method="POST" action="/api/admin/approve-request">
              <input type="hidden" name="requestId" value={req.id} />
              <button type="submit" class="text-sm font-medium bg-[#2D4A2D] text-white px-4 py-2 rounded-lg hover:bg-[#1F361F] focus-visible:ring-2 focus-visible:ring-[#2D4A2D]/50 focus-visible:outline-none transition-colors">
                Approve
              </button>
            </form>
            <form method="POST" action="/api/admin/deny-request" onsubmit="return confirm('Deny this organizer application? This cannot be undone.')">
              <input type="hidden" name="requestId" value={req.id} />
              <button type="submit" class="text-sm font-medium border border-gray-300 text-gray-600 px-4 py-2 rounded-lg hover:bg-gray-50 focus-visible:ring-2 focus-visible:ring-[#2D4A2D]/50 focus-visible:outline-none transition-colors">
                Deny
              </button>
            </form>
          </div>
        </div>
      ))}
    </div>
  )}

  {reviewed.length > 0 && (
    <div class="space-y-4">
      <h2 class="text-lg font-semibold text-gray-700">Previously Reviewed ({reviewed.length})</h2>
      {reviewed.map((req) => (
        <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
          <div class="flex items-center justify-between">
            <div>
              <span class="font-medium text-gray-700">{req.orgName}</span>
              <span class="text-xs text-gray-500 ml-2">{req.createdAtStr}</span>
            </div>
            <span class:list={[
              "text-xs font-medium px-2 py-0.5 rounded-full border",
              req.status === 'approved' ? "bg-green-50 text-green-700 border-green-200" : "bg-red-50 text-red-600 border-red-200"
            ]}>
              {req.status === 'approved' ? 'Approved' : 'Denied'}
            </span>
          </div>
        </div>
      ))}
    </div>
  )}
</Layout>
