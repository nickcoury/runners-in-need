---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { getDb, schema } from '../../db';
import { desc } from 'drizzle-orm';

const session = (Astro.locals as any).session;

const db = getDb();
const drives = await db.query.pledgeDrives.findMany({
  orderBy: [desc(schema.pledgeDrives.createdAt)],
});

const drivesFormatted = drives.map((d) => ({
  ...d,
  eventDateStr: d.eventDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }),
  createdAtStr: d.createdAt.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }),
}));

const statusStyles: Record<string, string> = {
  planned: 'bg-blue-50 text-blue-700 border-blue-200',
  active: 'bg-green-50 text-green-700 border-green-200',
  completed: 'bg-gray-100 text-gray-500 border-gray-200',
  cancelled: 'bg-red-50 text-red-600 border-red-200',
};

const statusLabels: Record<string, string> = {
  planned: 'Planned',
  active: 'Active',
  completed: 'Completed',
  cancelled: 'Cancelled',
};
---

<Layout title="Pledge Drives (Admin)">
  <h1 class="text-3xl font-bold mb-2">Pledge Drives</h1>
  <p class="text-gray-500 text-sm mb-6">All pledge drives submitted by users.</p>

  <div class="mb-4 text-sm">
    <a href="/admin/requests" class="text-[#2D4A2D] hover:underline">&larr; Back to Organizer Requests</a>
  </div>

  {drivesFormatted.length === 0 ? (
    <div class="border border-dashed border-gray-300 rounded-lg p-8 text-center text-gray-400">
      <p>No pledge drives have been submitted yet.</p>
    </div>
  ) : (
    <div class="space-y-4">
      {drivesFormatted.map((drive) => (
        <div class="bg-white border border-gray-200 rounded-lg p-5">
          <div class="flex items-start justify-between gap-4 mb-2">
            <div>
              <h3 class="font-semibold text-gray-900">{drive.eventName}</h3>
              <p class="text-xs text-gray-500">
                {drive.groupName} &middot; {drive.organizerName} ({drive.organizerEmail})
              </p>
            </div>
            <span class:list={[
              "text-xs font-medium px-2 py-0.5 rounded-full border shrink-0",
              statusStyles[drive.status] || statusStyles.planned,
            ]}>
              {statusLabels[drive.status] || drive.status}
            </span>
          </div>
          <div class="text-sm text-gray-600 mb-2">
            <span class="font-medium">Event:</span> {drive.eventDateStr} &middot; {drive.eventLocation}
            {drive.estimatedAttendees && (
              <span> &middot; ~{drive.estimatedAttendees} attendees</span>
            )}
          </div>
          <p class="text-sm text-gray-600 mb-2">{drive.description}</p>
          <p class="text-xs text-gray-400">Submitted {drive.createdAtStr}</p>
        </div>
      ))}
    </div>
  )}
</Layout>
