---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";

const callbackUrl = Astro.url.searchParams.get('callbackUrl') || '/';
---

<Layout title="Sign In">
  <div class="max-w-sm mx-auto py-16">
    <h1 class="text-2xl font-bold mb-6 text-center">Sign In</h1>

    <div class="space-y-4">
      {/* Magic link */}
      <form method="POST" action="/api/auth/signin/resend" class="signin-form space-y-3">
        <input type="hidden" name="csrfToken" value="" />
        <input type="hidden" name="callbackUrl" value={callbackUrl} />
        <label for="email" class="block text-sm font-medium text-gray-700">
          Email address
        </label>
        <input
          id="email"
          name="email"
          type="email"
          required
          placeholder="you@example.com"
          class="w-full border rounded-lg px-3 py-2 text-sm"
        />
        <button
          type="submit"
          class="w-full bg-green-700 text-white py-2 rounded-lg hover:bg-green-800 text-sm"
        >
          Send magic link
        </button>
      </form>

      <div class="relative py-2">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-gray-200"></div>
        </div>
        <div class="relative flex justify-center text-xs">
          <span class="px-2 bg-white text-gray-400">or</span>
        </div>
      </div>

      {/* Google OAuth */}
      <form method="POST" action="/api/auth/signin/google" class="signin-form">
        <input type="hidden" name="csrfToken" value="" />
        <input type="hidden" name="callbackUrl" value={callbackUrl} />
        <button
          type="submit"
          class="w-full border border-gray-300 py-2 rounded-lg hover:bg-gray-50 text-sm flex items-center justify-center gap-2"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          Continue with Google
        </button>
      </form>
    </div>

    <p class="text-xs text-gray-400 text-center mt-6" data-testid="signin-legal">
      By signing in, you agree to our <a href="/terms" class="underline hover:text-gray-600">terms of service</a> and <a href="/privacy" class="underline hover:text-gray-600">privacy policy</a>.
    </p>
  </div>

  <script>
    // Fetch CSRF token client-side so the browser receives the cookie
    fetch('/api/auth/csrf')
      .then(r => r.json())
      .then(data => {
        document.querySelectorAll<HTMLInputElement>('.signin-form input[name="csrfToken"]')
          .forEach(input => { input.value = data.csrfToken; });
      });
  </script>
</Layout>
