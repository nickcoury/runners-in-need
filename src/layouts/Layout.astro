---
import '../styles/global.css'

interface Props {
  title: string;
  description?: string;
  fullWidth?: boolean;
}

const { title, description = 'Connecting runners who have extra gear with organizations serving runners in need.', fullWidth = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#2D4A2D" />
    <meta property="og:title" content={`${title} | Runners In Need`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Runners In Need" />
    <meta name="twitter:card" content="summary" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Runners In Need</title>
    <style>
      @view-transition {
        navigation: auto;
      }
      ::view-transition-old(root),
      ::view-transition-new(root) {
        animation-duration: 150ms;
        animation-timing-function: ease-in-out;
      }
      ::view-transition-old(site-header),
      ::view-transition-new(site-header) {
        animation: none;
      }
    </style>
  </head>
  <body class="min-h-screen bg-gray-50 text-gray-900 flex flex-col">
    <header class="bg-[#2D4A2D] text-white sticky top-0 z-50" style="view-transition-name: site-header; contain: layout;">
      <nav class="max-w-6xl mx-auto px-4 py-3 flex items-center gap-6">
        <a href="/" class="text-xl font-bold shrink-0">Runners In Need</a>

        <div class="flex-1 max-w-md hidden md:block">
          <input
            type="text"
            placeholder="Search needs, items, locations..."
            class="w-full rounded-lg px-3 py-1.5 text-sm text-gray-900 placeholder-gray-400 bg-white border-0 focus:ring-2 focus:ring-white/50"
          />
        </div>

        <div class="hidden md:flex items-center gap-5 text-sm ml-auto">
          <a href="/browse" class="hover:text-green-200 transition-colors">Explore</a>
          <a href="/post" class="hover:text-green-200 transition-colors">Post a Need</a>
          <a href="/browse#map" class="hover:text-green-200 transition-colors">Map</a>
          <a href="/why" class="hover:text-green-200 transition-colors">Why</a>
          <a href="/about" class="hover:text-green-200 transition-colors">About</a>
          <a href="/auth/signin" class="bg-white/15 hover:bg-white/25 px-3 py-1 rounded-lg transition-colors">Sign In</a>
        </div>

        <button id="mobile-menu-btn" class="md:hidden ml-auto p-1" aria-label="Toggle menu" aria-expanded="false">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </nav>

      <div id="mobile-menu" class="hidden md:hidden bg-[#2D4A2D] border-t border-white/10 px-4 pb-4">
        <div class="py-2">
          <input
            type="text"
            placeholder="Search needs, items, locations..."
            class="w-full rounded-lg px-3 py-1.5 text-sm text-gray-900 placeholder-gray-400 bg-white border-0 focus:ring-2 focus:ring-white/50"
          />
        </div>
        <div class="flex flex-col gap-3 text-sm pt-2">
          <a href="/browse" class="hover:text-green-200 transition-colors">Explore</a>
          <a href="/post" class="hover:text-green-200 transition-colors">Post a Need</a>
          <a href="/browse#map" class="hover:text-green-200 transition-colors">Map</a>
          <a href="/why" class="hover:text-green-200 transition-colors">Why</a>
          <a href="/about" class="hover:text-green-200 transition-colors">About</a>
          <a href="/auth/signin" class="bg-white/15 hover:bg-white/25 px-3 py-1 rounded-lg transition-colors inline-block w-fit">Sign In</a>
        </div>
      </div>
    </header>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        const open = menu?.classList.toggle('hidden') === false;
        btn.setAttribute('aria-expanded', String(open));
      });
    </script>

    <main class:list={["flex-1 w-full", fullWidth ? "" : "max-w-6xl mx-auto px-4 py-6"]}>
      <slot />
    </main>

    <footer class="bg-[#2D4A2D] text-green-100 mt-auto">
      <div class="max-w-6xl mx-auto px-4 py-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm">
        <p>Runners In Need &mdash; Connecting gear with those who need it most.</p>
        <div class="flex gap-4 text-green-300">
          <a href="/about" class="hover:text-white">About</a>
          <a href="/terms" class="hover:text-white">Terms</a>
          <a href="/privacy" class="hover:text-white">Privacy</a>
          <a href="/contact" class="hover:text-white">Contact</a>
        </div>
      </div>
    </footer>
  </body>
</html>
