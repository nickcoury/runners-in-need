---
import '../styles/global.css'

interface Props {
  title: string;
  description?: string;
  fullWidth?: boolean;
  ogType?: string;
}

const { title, description = 'Connecting runners who have extra gear with organizations serving runners in need.', fullWidth = false, ogType = 'website' } = Astro.props;
const fullTitle = `${title} | Runners In Need`;
const canonicalUrl = new URL(Astro.url.pathname, 'https://runnersinneed.com').href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#2D4A2D" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Runners In Need" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Runners In Need",
      "url": "https://runnersinneed.com"
    }
    </script>
    <style>
      @view-transition {
        navigation: auto;
      }
      ::view-transition-old(root),
      ::view-transition-new(root) {
        animation-duration: 150ms;
        animation-timing-function: ease-in-out;
      }
      ::view-transition-old(site-header),
      ::view-transition-new(site-header) {
        animation: none;
      }
    </style>
  </head>
  <body class="min-h-screen bg-gray-50 text-gray-900 flex flex-col">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[100] focus:bg-white focus:text-[#2D4A2D] focus:px-4 focus:py-2 focus:rounded-lg focus:shadow-lg focus:text-sm focus:font-medium">Skip to main content</a>
    <header class="bg-[#2D4A2D] text-white sticky top-0 z-50" style="view-transition-name: site-header;">
      <nav aria-label="Main navigation" class="max-w-6xl mx-auto px-4 py-3 flex items-center gap-6">
        <a href="/" class="text-xl font-bold shrink-0">Runners In Need</a>

        <div class="hidden md:flex items-center gap-5 text-sm ml-auto">
          <a href="/post" class="hover:text-green-200 focus-visible:text-green-200 focus-visible:outline-none transition-colors">Post a Need</a>
          <a href="/drives" class="hover:text-green-200 focus-visible:text-green-200 focus-visible:outline-none transition-colors">Pledge Drives</a>
          <a href="/why" class="hover:text-green-200 focus-visible:text-green-200 focus-visible:outline-none transition-colors">Why</a>
          <a href="/about" class="hover:text-green-200 focus-visible:text-green-200 focus-visible:outline-none transition-colors">About</a>

          {/* Signed-out state */}
          <a id="auth-link" href="/auth/signin" class="bg-white/15 hover:bg-white/25 focus-visible:bg-white/25 focus-visible:ring-2 focus-visible:ring-white/50 focus-visible:outline-none px-3 py-1 rounded-lg transition-colors">Get Started</a>

          {/* Signed-in state — hidden by default, shown by JS */}
          <div id="user-menu" class="relative hidden">
            <button id="user-menu-btn" aria-label="User menu" aria-haspopup="true" aria-expanded="false" class="flex items-center gap-2 bg-white/15 hover:bg-white/25 focus-visible:bg-white/25 focus-visible:ring-2 focus-visible:ring-white/50 focus-visible:outline-none pl-1.5 pr-3 py-1 rounded-lg transition-colors">
              <span id="user-avatar" class="w-6 h-6 rounded-full bg-white/30 flex items-center justify-center text-xs font-bold overflow-hidden">
                <span id="user-initials"></span>
              </span>
              <span id="user-name-display" class="max-w-[120px] truncate"></span>
              <svg class="w-3.5 h-3.5 opacity-70" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div id="user-dropdown" role="menu" class="hidden absolute right-0 top-full mt-1 w-56 bg-white rounded-lg shadow-lg border border-gray-200 py-1 z-50 text-gray-700">
              <div id="dropdown-user-info" class="px-4 py-2.5 border-b border-gray-100">
                <p id="dropdown-name" class="text-sm font-medium text-gray-900 truncate"></p>
                <p id="dropdown-email" class="text-xs text-gray-500 truncate"></p>
              </div>
              <a href="/dashboard" role="menuitem" class="block px-4 py-2 text-sm hover:bg-gray-50 focus-visible:bg-gray-50 focus-visible:outline-none transition-colors">Dashboard</a>
              <a href="/profile" role="menuitem" class="block px-4 py-2 text-sm hover:bg-gray-50 focus-visible:bg-gray-50 focus-visible:outline-none transition-colors">Profile</a>
              <a id="admin-link" href="/admin" role="menuitem" class="hidden px-4 py-2 text-sm hover:bg-gray-50 focus-visible:bg-gray-50 focus-visible:outline-none transition-colors">Admin</a>
              <div class="border-t border-gray-100 mt-1 pt-1">
                <button id="sign-out-btn" role="menuitem" class="w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-red-50 focus-visible:bg-red-50 focus-visible:outline-none transition-colors">Sign Out</button>
              </div>
            </div>
          </div>
        </div>

        <button id="mobile-menu-btn" class="md:hidden ml-auto p-2.5" aria-label="Toggle menu" aria-expanded="false">
          <svg class="w-6 h-6" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </nav>

      <div id="mobile-menu" class="hidden md:hidden bg-[#2D4A2D] border-t border-white/10 px-4 pb-4">
        <div class="flex flex-col gap-3 text-sm pt-3">
          <a href="/post" class="hover:text-green-200 focus-visible:text-green-200 focus-visible:outline-none transition-colors">Post a Need</a>
          <a href="/drives" class="hover:text-green-200 focus-visible:text-green-200 focus-visible:outline-none transition-colors">Pledge Drives</a>
          <a href="/why" class="hover:text-green-200 focus-visible:text-green-200 focus-visible:outline-none transition-colors">Why</a>
          <a href="/about" class="hover:text-green-200 focus-visible:text-green-200 focus-visible:outline-none transition-colors">About</a>

          {/* Mobile: signed-out */}
          <a id="auth-link-mobile" href="/auth/signin" class="bg-white/15 hover:bg-white/25 focus-visible:bg-white/25 focus-visible:ring-2 focus-visible:ring-white/50 focus-visible:outline-none px-3 py-1 rounded-lg transition-colors inline-block w-fit">Get Started</a>

          {/* Mobile: signed-in — hidden by default */}
          <div id="mobile-user-section" class="hidden space-y-2 pt-1 border-t border-white/10">
            <div class="flex items-center gap-2 py-1">
              <span id="mobile-user-avatar" class="w-6 h-6 rounded-full bg-white/30 flex items-center justify-center text-xs font-bold overflow-hidden">
                <span id="mobile-user-initials"></span>
              </span>
              <span id="mobile-user-name" class="text-sm font-medium truncate"></span>
            </div>
            <a href="/dashboard" class="block hover:text-green-200 focus-visible:text-green-200 focus-visible:outline-none transition-colors">Dashboard</a>
            <a href="/profile" class="block hover:text-green-200 focus-visible:text-green-200 focus-visible:outline-none transition-colors">Profile</a>
            <a id="mobile-admin-link" href="/admin" class="hidden hover:text-green-200 focus-visible:text-green-200 focus-visible:outline-none transition-colors">Admin</a>
            <button id="mobile-sign-out-btn" class="text-red-300 hover:text-red-200 focus-visible:text-red-200 focus-visible:outline-none transition-colors text-left">Sign Out</button>
          </div>
        </div>
      </div>
    </header>

    <script>
      import '../scripts/header-nav';
    </script>

    <main id="main-content" class:list={["flex-1 w-full", fullWidth ? "" : "max-w-6xl mx-auto px-4 py-6"]}>
      <slot />
    </main>

    <footer class="bg-[#2D4A2D] text-green-100 mt-auto">
      <div class="max-w-6xl mx-auto px-4 py-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm">
        <p>Runners In Need &mdash; Connecting gear with those who need it most.</p>
        <div class="flex flex-wrap gap-4 text-green-300">
          <a href="/about" class="hover:text-white focus-visible:text-white focus-visible:outline-none">About</a>
          <a href="/why" class="hover:text-white focus-visible:text-white focus-visible:outline-none">Why</a>
          <a href="/terms" class="hover:text-white focus-visible:text-white focus-visible:outline-none">Terms</a>
          <a href="/privacy" class="hover:text-white focus-visible:text-white focus-visible:outline-none">Privacy</a>
          <a href="/contact" class="hover:text-white focus-visible:text-white focus-visible:outline-none">Contact</a>
          <a href="/become-organizer" class="hover:text-white focus-visible:text-white focus-visible:outline-none">Become an Organizer</a>
        </div>
      </div>
    </footer>

    {/* Back to top button */}
    <button
      id="back-to-top"
      type="button"
      aria-label="Back to top"
      class="fixed bottom-6 right-6 z-40 hidden w-10 h-10 rounded-full bg-[#2D4A2D] text-white shadow-lg hover:bg-[#1F361F] focus-visible:ring-2 focus-visible:ring-[#2D4A2D]/50 focus-visible:ring-offset-2 focus-visible:outline-none transition-all items-center justify-center"
    >
      <svg class="w-5 h-5" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" /></svg>
    </button>
  </body>
</html>
