---
interface Props {
  id: string;
  title: string;
  categoryTag: string;
  body: string;
  orgName: string;
  location: string;
  extrasWelcome: boolean;
  status: string;
  expiresAt: Date;
  pledgeCount?: number;
}

const { id, title, categoryTag, body, orgName, location, extrasWelcome, status, expiresAt, pledgeCount = 0 } = Astro.props;

const categoryStyles: Record<string, string> = {
  shoes: "bg-[#2D4A2D] text-white",
  apparel: "bg-blue-600 text-white",
  accessories: "bg-amber-600 text-white",
  other: "bg-gray-500 text-white",
};

const categoryLabels: Record<string, string> = {
  shoes: "Shoes",
  apparel: "Apparel",
  accessories: "Accessories",
  other: "Other",
};

const daysUntilExpiry = Math.ceil((expiresAt.getTime() - Date.now()) / (1000 * 60 * 60 * 24));
---

<div class="need-card bg-white border border-gray-200 rounded-lg p-4 flex flex-col hover:border-[#3D7A3D] transition-colors" data-category={categoryTag} data-searchable={`${title} ${body} ${orgName} ${location}`.toLowerCase()}>
  {/* Category badge + extras */}
  <div class="flex items-center gap-2 mb-2">
    <span class:list={["text-xs font-medium px-2 py-0.5 rounded-full", categoryStyles[categoryTag] || categoryStyles.other]}>
      {categoryLabels[categoryTag] || "Other"}
    </span>
    {extrasWelcome && (
      <span class="text-xs bg-green-50 text-green-700 px-2 py-0.5 rounded-full border border-green-200">
        + Extras welcome
      </span>
    )}
  </div>

  {/* Title */}
  <a href={`/needs/${id}`} class="font-semibold text-gray-900 hover:text-[#2D4A2D] mb-1 line-clamp-2">
    {title}
  </a>

  {/* Org + location */}
  <p class="text-xs text-gray-500 mb-2">{orgName} &middot; {location}</p>

  {/* Description */}
  <p class="text-sm text-gray-600 line-clamp-3 mb-3 whitespace-pre-line flex-1">{body}</p>

  {/* Footer: metadata */}
  <div class="flex items-center justify-between text-xs text-gray-400 mb-3">
    <span>{pledgeCount} pledge{pledgeCount !== 1 ? "s" : ""}</span>
    <span class:list={[daysUntilExpiry <= 14 ? "text-amber-600 font-medium" : ""]}>
      {daysUntilExpiry > 0 ? `${daysUntilExpiry} days left` : "Expired"}
    </span>
  </div>

  {/* Action button */}
  <a
    href={`/needs/${id}`}
    class="block text-center bg-[#2D4A2D] text-white text-sm font-medium py-2 rounded-lg hover:bg-[#1F361F] transition-colors"
  >
    MATCH NEED
  </a>
</div>
