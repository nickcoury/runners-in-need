# Runners In Need - Environment Variables
# Copy this file to .env and fill in values.
# NEVER commit .env to git — only .env.example is tracked.

# === Database (Turso) ===
TURSO_DATABASE_URL=libsql://your-db-name-your-username.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# === Auth.js ===
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here

# === Resend (Magic Link Emails) ===
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Google OAuth (optional) ===
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# === Cloudflare Turnstile ===
TURNSTILE_SITE_KEY=0x4xxxxxxxxxxxxxxxxxxxxxxxxx
TURNSTILE_SECRET_KEY=0x4xxxxxxxxxxxxxxxxxxxxxxxxx

# === Claude API (for LLM features) ===
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# === App ===
# The public URL of your site (used for auth callbacks, emails, etc.)
PUBLIC_SITE_URL=http://localhost:4321
