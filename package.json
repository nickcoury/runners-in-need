{
  "name": "runners-in-need",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "check": "astro check",
    "preview": "astro preview",
    "astro": "astro",
    "generate-types": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push --force",
    "db:studio": "drizzle-kit studio",
    "db:seed": "node --env-file=.env --experimental-strip-types src/db/seed.ts",
    "test": "npx playwright test",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:smoke": "npx playwright test tests/e2e/smoke.spec.ts --config=playwright.smoke.config.ts",
    "test:ci-smoke": "npx playwright test --config=playwright.ci.config.ts",
    "test:prod-smoke": "npx playwright test --config=playwright.prod.config.ts",
    "verify": "npm run check && npm run test:smoke"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.7",
    "@astrojs/react": "^5.0.2",
    "@auth/drizzle-adapter": "^1.11.1",
    "@libsql/client": "^0.17.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.1.3",
    "auth-astro": "^4.2.0",
    "drizzle-orm": "^0.45.2",
    "leaflet": "^1.9.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.10.0",
    "tailwindcss": "^4.2.1",
    "wrangler": "^4.80.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.59.1",
    "@types/leaflet": "^1.9.21",
    "dotenv": "^17.4.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3"
  }
}
